---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';

const reserves = [
  {
    name: 'Prästbonnaskogen',
    meta: '500 m norr om stationen',
    text: 'Naturreservat med nyrestaurerad strandäng och vandringsslingor. Här finns rast- och grillplatser. Förvaltas av Länsstyrelsen.',
  },
  {
    name: 'Lergravarna',
    meta: 'ca 1 km från stationen',
    text: 'Naturreservat med en kortare spångad led. En liten parkering finns intill (utanför reningsverkets grindar).',
  },
];
---
<Base
  title="Natur & sjön"
  description="Tjörnarpssjön, vandringsleder, naturreservat, bad och fiske i Tjörnarp."
>
  <PageHeader
    eyebrow="Natur & sjön"
    title="Ut i naturen"
    lead="Tjörnarp ligger vackert vid sjön i ett böljande landskap. Här finns vandringsleder, naturreservat, bad och gott om fiske – och bra tågförbindelse för dagsbesök."
  />

  <section class="mx-auto max-w-4xl px-5 py-14">
    <!-- Lake -->
    <div class="prose-tjornarp max-w-none">
      <h2>Tjörnarpssjön</h2>
      <p>
        Sjön är hjärtat i bygden. Här kan du bada, ro och fiska. Längs
        sjöpromenaden finns grillplatser, och vid sjön finns en badplats och
        kastbryggor för fiske.
      </p>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="rounded-2xl border border-forest-700/10 bg-paper p-5">
        <h3 class="font-display text-lg text-forest-800">Bad</h3>
        <p class="mt-1 text-sm text-ink-soft">Anlagd badplats vid sjön.</p>
      </div>
      <div class="rounded-2xl border border-forest-700/10 bg-paper p-5">
        <h3 class="font-display text-lg text-forest-800">Fiske</h3>
        <p class="mt-1 text-sm text-ink-soft">Gädda, abborre, gös, braxen och mört. Fiskekort krävs (via iFiske). Barn upp till 15 år fiskar gratis i målsmans sällskap.</p>
      </div>
      <div class="rounded-2xl border border-forest-700/10 bg-paper p-5">
        <h3 class="font-display text-lg text-forest-800">Båt</h3>
        <p class="mt-1 text-sm text-ink-soft">Tre roddbåtar att hyra hos fiskekortsförsäljarna. Elmotor tillåten; bensinbåt och vattenskoter ej tillåtna.</p>
      </div>
    </div>

    <!-- Trails / reserves -->
    <div class="prose-tjornarp mt-14 max-w-none">
      <h2>Vandringsleder & naturreservat</h2>
      <p>
        Med fin utsikt över Tjörnarpssjön kan du vandra i omväxlande miljöer –
        betes- och odlingsmark blandat med skog. Flera av lederna sköts av
        Tjörnarps Sockengille. Området nås enkelt med Pågatåg.
      </p>
    </div>

    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      {reserves.map((r) => (
        <article class="rounded-2xl border border-forest-700/10 bg-paper p-6">
          <h3 class="font-display text-xl text-forest-800">{r.name}</h3>
          <p class="mt-1 text-sm font-semibold uppercase tracking-wide text-lake-600">{r.meta}</p>
          <p class="mt-3 leading-relaxed text-ink-soft">{r.text}</p>
        </article>
      ))}
    </div>

    <div class="mt-10 rounded-2xl bg-lake-100 p-6">
      <h2 class="font-display text-xl text-lake-700">Karta & mer information</h2>
      <p class="mt-2 text-ink-soft">
        Höörs kommun har detaljerade beskrivningar och en nedladdningsbar
        kartfolder över lederna.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="https://www.hoor.se/uppleva-gora/idrott-motion-och-friluftsliv/friluftsliv-och-motion/motionsslingor-och-naturomraden/tjornarps-vandringsleder/" target="_blank" rel="noopener" class="rounded-full bg-lake-600 px-5 py-2.5 text-sm font-semibold text-cream hover:bg-lake-700">Vandringsleder (hoor.se)</a>
        <a href="https://www.hoor.se/uppleva-gora/idrott-motion-och-friluftsliv/friluftsliv-och-motion/fiske/tjornarpssjon/" target="_blank" rel="noopener" class="rounded-full bg-paper px-5 py-2.5 text-sm font-semibold text-lake-700 ring-1 ring-lake-600/30 hover:bg-lake-100">Om sjön & fiske (hoor.se)</a>
      </div>
    </div>
  </section>
</Base>
