---
import Base from '../layouts/Base.astro';
---
<Base title="Tack" description="Tack för ditt meddelande.">
  <section class="mx-auto flex max-w-2xl flex-col items-center px-5 py-28 text-center">
    <div class="flex h-16 w-16 items-center justify-center rounded-full bg-forest-100 text-forest-700">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7"/></svg>
    </div>
    <h1 class="mt-6 text-4xl text-forest-800">Tack för ditt meddelande!</h1>
    <p class="mt-4 text-lg text-ink-soft">Vi har tagit emot det och hör av oss om det behövs.</p>
    <a href="/" class="mt-8 rounded-full bg-forest-700 px-6 py-3 text-sm font-semibold text-cream hover:bg-forest-800">Till startsidan</a>
  </section>
</Base>
