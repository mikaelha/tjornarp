---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { site } from '../lib/site';
---
<Base
  title="Kontakt"
  description="Kontakta Tjörnarps Sockengille – tipsa om nyheter och evenemang eller anmäl din förening eller ditt företag."
>
  <PageHeader
    eyebrow="Kontakt"
    title="Hör av dig"
    lead="Har du en nyhet, ett evenemang eller en förening/ett företag som borde finnas med? Hör av dig till Tjörnarps Sockengille."
  />

  <section class="mx-auto max-w-5xl px-5 py-14">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr]">
      <!-- Form (Netlify Forms – no login needed for submitters) -->
      <div>
        <h2 class="font-display text-2xl text-forest-800">Skicka ett meddelande</h2>
        <p class="mt-2 text-ink-soft">Tipsa om något, eller be om att få din förening eller ditt företag tillagt.</p>

        <form
          name="kontakt"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/tack/"
          class="mt-6 space-y-4"
        >
          <input type="hidden" name="form-name" value="kontakt" />
          <p class="hidden">
            <label>Lämna tomt: <input name="bot-field" /></label>
          </p>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm font-semibold text-forest-800">Namn</span>
              <input type="text" name="namn" required class="mt-1 w-full rounded-xl border border-forest-700/15 bg-paper px-4 py-2.5 text-ink outline-none focus:border-forest-600" />
            </label>
            <label class="block">
              <span class="text-sm font-semibold text-forest-800">E-post</span>
              <input type="email" name="epost" required class="mt-1 w-full rounded-xl border border-forest-700/15 bg-paper px-4 py-2.5 text-ink outline-none focus:border-forest-600" />
            </label>
          </div>

          <label class="block">
            <span class="text-sm font-semibold text-forest-800">Vad gäller det?</span>
            <select name="amne" class="mt-1 w-full rounded-xl border border-forest-700/15 bg-paper px-4 py-2.5 text-ink outline-none focus:border-forest-600">
              <option>Tips om nyhet</option>
              <option>Tips om evenemang</option>
              <option>Lägg till förening</option>
              <option>Lägg till företag</option>
              <option>Bidra med bilder</option>
              <option>Annat</option>
            </select>
          </label>

          <label class="block">
            <span class="text-sm font-semibold text-forest-800">Meddelande</span>
            <textarea name="meddelande" rows="6" required class="mt-1 w-full rounded-xl border border-forest-700/15 bg-paper px-4 py-2.5 text-ink outline-none focus:border-forest-600"></textarea>
          </label>

          <button type="submit" class="rounded-full bg-forest-700 px-6 py-3 text-sm font-semibold text-cream transition-colors hover:bg-forest-800">Skicka</button>
        </form>
      </div>

      <!-- Direct contact -->
      <aside class="space-y-6">
        <div class="rounded-2xl border border-forest-700/10 bg-paper p-6">
          <h2 class="font-display text-xl text-forest-800">Tjörnarps Sockengille</h2>
          <p class="mt-3 text-ink-soft">Frostavägen 4<br />243 72 Tjörnarp</p>
          <p class="mt-2 text-sm text-ink-soft/80">Org.nr 842000-9782</p>
          <ul class="mt-4 space-y-2 text-sm">
            <li><a class="font-semibold text-forest-700 hover:text-tegel-600" href={`mailto:${site.email}`}>{site.email}</a></li>
            <li><a class="font-semibold text-forest-700 hover:text-tegel-600" href={site.social.facebookSockengille} target="_blank" rel="noopener">Sockengillet på Facebook →</a></li>
            <li><a class="font-semibold text-forest-700 hover:text-tegel-600" href={site.social.historia} target="_blank" rel="noopener">tjornarpshistoria.se →</a></li>
          </ul>
        </div>

        <div class="rounded-2xl bg-lake-100 p-6">
          <h2 class="font-display text-xl text-lake-700">Byns Facebookgrupp</h2>
          <p class="mt-2 text-sm text-ink-soft">Snabbaste sättet att nå grannar och få lokala nyheter.</p>
          <a class="mt-3 inline-block rounded-full bg-lake-600 px-5 py-2.5 text-sm font-semibold text-cream hover:bg-lake-700" href={site.social.facebook} target="_blank" rel="noopener">Till gruppen</a>
        </div>
      </aside>
    </div>
  </section>
</Base>
