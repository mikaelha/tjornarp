---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import DirectoryCard from '../components/DirectoryCard.astro';

const all = (await getCollection('foreningar')).sort(
  (a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name, 'sv'),
);

const categoryOrder = ['Idrott', 'Kultur & hembygd', 'Natur & friluft', 'Barn & ungdom', 'Övrigt'];
const grouped = categoryOrder
  .map((cat) => ({ cat, items: all.filter((f) => f.data.category === cat) }))
  .filter((g) => g.items.length > 0);
---
<Base title="Föreningar" description="Föreningar och föreningsliv i Tjörnarp.">
  <PageHeader
    eyebrow="Föreningar"
    title="Föreningslivet i byn"
    lead="Tjörnarp har ett rikt föreningsliv. Saknas din förening? Hör av dig så lägger vi till den."
  />

  <section class="mx-auto max-w-5xl px-5 py-14">
    {grouped.length === 0 ? (
      <p class="rounded-2xl border border-dashed border-forest-700/20 bg-paper p-6 text-ink-soft">Inga föreningar inlagda ännu.</p>
    ) : (
      <div class="space-y-12">
        {grouped.map(({ cat, items }) => (
          <div>
            <h2 class="mb-5 text-2xl text-forest-800">{cat}</h2>
            <div class="grid gap-5 sm:grid-cols-2">
              {items.map((f) => (
                <DirectoryCard
                  name={f.data.name}
                  summary={f.data.summary}
                  website={f.data.website}
                  facebook={f.data.facebook}
                  email={f.data.email}
                  phone={f.data.phone}
                  contactPerson={f.data.contactPerson}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    )}

    <div class="mt-14 rounded-2xl bg-forest-100 p-6 text-center">
      <p class="text-forest-800">Är din förening inte med – eller har uppgifter ändrats?</p>
      <a href="/kontakt/" class="mt-3 inline-block rounded-full bg-forest-700 px-5 py-2.5 text-sm font-semibold text-cream hover:bg-forest-800">Hör av dig</a>
    </div>
  </section>
</Base>
