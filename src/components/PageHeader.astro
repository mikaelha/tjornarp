---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---
<section class="grain border-b border-forest-700/10 bg-cream-deep">
  <div class="mx-auto max-w-6xl px-5 pb-12 pt-14 sm:pt-16">
    {eyebrow && (
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-tegel-600">{eyebrow}</p>
    )}
    <h1 class="max-w-3xl text-4xl text-forest-800 sm:text-5xl">{title}</h1>
    {lead && <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-soft">{lead}</p>}
    <slot />
  </div>
</section>
