---
import Logo from './Logo.astro';
import { nav, site } from '../lib/site';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---
<header class="sticky top-0 z-50 border-b border-forest-700/10 bg-cream/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3">
    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="Tjörnarp – till startsidan">
      <Logo class="h-9 w-9" />
      <span class="font-display text-xl font-semibold tracking-tight text-forest-800">Tjörnarp</span>
    </a>

    <nav class="hidden lg:block" aria-label="Huvudmeny">
      <ul class="flex items-center gap-1">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={[
                'rounded-full px-3 py-2 text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'bg-forest-700 text-cream'
                  : 'text-ink-soft hover:bg-forest-100 hover:text-forest-800',
              ]}
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Mobile menu (CSS-only toggle, no JS) -->
    <details class="group relative lg:hidden">
      <summary
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full text-forest-800 hover:bg-forest-100"
        aria-label="Öppna meny"
      >
        <svg class="h-6 w-6 group-open:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"/></svg>
        <svg class="hidden h-6 w-6 group-open:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 6l12 12M18 6L6 18"/></svg>
      </summary>
      <div class="absolute right-0 mt-2 w-60 rounded-2xl border border-forest-700/10 bg-paper p-2 shadow-xl shadow-forest-800/10">
        <ul class="flex flex-col">
          {nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'block rounded-xl px-4 py-2.5 text-sm font-medium',
                  isActive(item.href) ? 'bg-forest-700 text-cream' : 'text-ink-soft hover:bg-forest-100',
                ]}
              >{item.label}</a>
            </li>
          ))}
          <li class="mt-1 border-t border-forest-700/10 pt-1">
            <a href="/kontakt" class="block rounded-xl px-4 py-2.5 text-sm font-medium text-ink-soft hover:bg-forest-100">Kontakt</a>
          </li>
        </ul>
      </div>
    </details>
  </div>
</header>
