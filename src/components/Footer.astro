---
import Logo from './Logo.astro';
import { nav, site } from '../lib/site';
const year = new Date().getFullYear();
---
<footer class="grain mt-24 bg-forest-800 text-cream/80">
  <div class="mx-auto max-w-6xl px-5 py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-2.5">
          <Logo class="h-9 w-9" />
          <span class="font-display text-xl font-semibold text-cream">Tjörnarp</span>
        </div>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-cream/70">
          Byn vid Tjörnarpssjön i Höörs kommun. En sida av och för bygden.
        </p>
        <p class="mt-4 text-sm text-cream/60">
          Sidan ägs och drivs av <span class="text-cream">Tjörnarps Sockengille</span>.
        </p>
      </div>

      <nav aria-label="Sidfot – sidor">
        <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-wheat-300">Sidor</h2>
        <ul class="mt-3 space-y-2 text-sm">
          {nav.map((item) => (
            <li><a class="text-cream/75 hover:text-cream hover:underline" href={item.href}>{item.label}</a></li>
          ))}
          <li><a class="text-cream/75 hover:text-cream hover:underline" href="/bibliotek">PDF-bibliotek</a></li>
          <li><a class="text-cream/75 hover:text-cream hover:underline" href="/galleri">Bildgalleri</a></li>
          <li><a class="text-cream/75 hover:text-cream hover:underline" href="/kontakt">Kontakt</a></li>
        </ul>
      </nav>

      <div>
        <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-wheat-300">Följ & läs mer</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="text-cream/75 hover:text-cream hover:underline" href={site.social.facebook} rel="noopener" target="_blank">Tjörnarp på Facebook</a></li>
          <li><a class="text-cream/75 hover:text-cream hover:underline" href={site.social.facebookSockengille} rel="noopener" target="_blank">Sockengillet på Facebook</a></li>
          <li><a class="text-cream/75 hover:text-cream hover:underline" href={site.social.historia} rel="noopener" target="_blank">tjornarpshistoria.se</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t border-cream/15 pt-6 text-xs text-cream/55 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} Tjörnarps Sockengille</p>
      <p>Tjörnarp, Höörs kommun, Skåne</p>
    </div>
  </div>
</footer>
