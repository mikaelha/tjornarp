---
// One entry in a förening/företag directory.
interface Props {
  name: string;
  summary?: string;
  website?: string;
  facebook?: string;
  instagram?: string;
  email?: string;
  phone?: string;
  contactPerson?: string;
  address?: string;
}
const { name, summary, website, facebook, instagram, email, phone, contactPerson, address } = Astro.props;
---
<article class="flex flex-col rounded-2xl border border-forest-700/10 bg-paper p-6">
  <h3 class="text-xl text-forest-800">{name}</h3>
  {summary && <p class="mt-2 flex-1 text-[15px] leading-relaxed text-ink-soft"><slot>{summary}</slot></p>}
  {contactPerson && <p class="mt-3 text-sm text-ink-soft">Kontakt: {contactPerson}</p>}
  {address && <p class="text-sm text-ink-soft">{address}</p>}

  {(website || facebook || instagram || email || phone) && (
    <ul class="mt-4 flex flex-wrap gap-2">
      {website && (
        <li><a href={website} target="_blank" rel="noopener" class="rounded-full bg-forest-100 px-3 py-1.5 text-sm font-medium text-forest-800 hover:bg-forest-300/40">Webbplats</a></li>
      )}
      {facebook && (
        <li><a href={facebook} target="_blank" rel="noopener" class="rounded-full bg-lake-100 px-3 py-1.5 text-sm font-medium text-lake-700 hover:bg-lake-100/70">Facebook</a></li>
      )}
      {instagram && (
        <li><a href={instagram} target="_blank" rel="noopener" class="rounded-full bg-tegel-100 px-3 py-1.5 text-sm font-medium text-tegel-600 hover:bg-tegel-100/70">Instagram</a></li>
      )}
      {email && (
        <li><a href={`mailto:${email}`} class="rounded-full bg-cream-deep px-3 py-1.5 text-sm font-medium text-ink hover:bg-forest-100">E-post</a></li>
      )}
      {phone && (
        <li><a href={`tel:${phone.replace(/\s+/g, '')}`} class="rounded-full bg-cream-deep px-3 py-1.5 text-sm font-medium text-ink hover:bg-forest-100">{phone}</a></li>
      )}
    </ul>
  )}
</article>
