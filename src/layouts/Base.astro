---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Set true on long-form article pages so the URL isn't suffixed with site name twice. */
  rawTitle?: boolean;
  /** og:type – use 'article' on news posts. */
  type?: 'website' | 'article';
  /** Publication date for article pages (emits article:published_time). */
  publishedTime?: Date;
  /** Page-specific JSON-LD object(s); merged with the site-wide Organization schema. */
  schema?: object | object[];
}

const {
  title,
  description = site.description,
  image = '/og-default.png',
  rawTitle = false,
  type = 'website',
  publishedTime,
  schema,
} = Astro.props;

const pageTitle = !title ? site.title : rawTitle ? title : `${title} – Tjörnarp`;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL(image, site.url).href;

// Site-wide Organization schema – the association that runs the site.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Tjörnarps Sockengille',
  alternateName: 'Tjörnarp',
  url: site.url,
  logo: new URL('/favicon-192.png', site.url).href,
  description: site.description,
  sameAs: [site.social.facebookSockengille, site.social.historia],
};
const jsonLd = [orgSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];

// Umami analytics (privacy-friendly, cookieless). The website ID is public, but we
// read it from an env var so the script only loads once configured. Set
// PUBLIC_UMAMI_WEBSITE_ID in Netlify (and .env locally) to enable.
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
---
<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Tjörnarp" />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    {jsonLd.map((s) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />
    ))}

    <!-- Analytics -->
    {umamiWebsiteId && (
      <script
        is:inline
        defer
        src="https://cloud.umami.is/script.js"
        data-website-id={umamiWebsiteId}
      />
    )}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Mulish:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-forest-700 focus:px-4 focus:py-2 focus:text-cream">Hoppa till innehåll</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
